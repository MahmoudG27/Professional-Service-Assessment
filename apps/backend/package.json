{
  "name": "cloudready-backend",
  "version": "1.0.0",
  "description": "CloudReady Assessment Tool - Azure Functions Backend",
  "main": "dist/functions/*.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 \"src/assets/**/*\" dist/",
    "watch": "tsc -w",
    "prestart": "npm run build",
    "start": "func start"
  },
  "dependencies": {
    "@azure/cosmos": "^4.1.0",
    "@azure/functions": "^4.5.0",
    "@azure/storage-blob": "^12.17.0",
    "openai": "^4.0.0",
    "pdfkit": "^0.18.0",
    "svg-to-pdfkit": "^0.1.8",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^9.0.0",
    "azure-functions-core-tools": "^4.x",
    "copyfiles": "^2.4.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  }
}
